generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CLIENT
  LAWYER
  ADMIN
}

enum CaseCategory {
  CONTRACT_REVIEW
  RENTAL_TENANCY
  EMPLOYMENT
  CYBER_COMPLAINT
  HARASSMENT
  PAYMENT_DISPUTE
  BUSINESS_VENDOR
  LEGAL_NOTICE
  EVIDENCE_ORGANIZATION
  OTHER
}

enum CaseStatus {
  DRAFT
  INTAKE
  ACTIVE
  REVIEW
  ESCALATED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum DocumentType {
  PDF
  IMAGE
  DOC
  DOCX
  EMAIL
  SCREENSHOT
  TEXT
  OTHER
}

enum UploadSource {
  USER_UPLOAD
  LAWYER_UPLOAD
  EMAIL_IMPORT
  SCREEN_CAPTURE
  SYSTEM_GENERATED
}

enum DraftType {
  COMPLAINT_LETTER
  LEGAL_NOTICE
  WARNING_LETTER
  RESPONSE_LETTER
  REFUND_REQUEST
  GRIEVANCE_SUBMISSION
  CONTRACT_REVISION
  OPINION_BRIEF
  OTHER
}

enum VerificationStatus {
  UNREVIEWED
  VERIFIED
  NEEDS_CORRECTION
}

enum CommentVisibility {
  SHARED
  PRIVATE
}

enum DeadlineStatus {
  UPCOMING
  OVERDUE
  COMPLETED
}

enum RedactionStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum AssistantScope {
  GENERAL
  CASE
  DOCUMENT
}

enum MessageRole {
  USER
  AI
  SYSTEM
}

enum DebateStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  passwordHash         String
  name                 String
  role                 Role
  avatarUrl            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  clientProfile        ClientProfile?
  lawyerProfile        LawyerProfile?
  createdCases         Case[]                @relation("CaseCreator")
  documents            Document[]
  comments             Comment[]
  internalNotes        InternalNote[]
  notifications        Notification[]
  activityLogs         ActivityLog[]
  draftVersions        DraftVersion[]
  createdDrafts        Draft[]               @relation("DraftCreator")
  verifiedDrafts       Draft[]               @relation("DraftVerifier")
  redactionJobs        RedactionJob[]
  exportBundles        ExportBundle[]
  agentActionReviews   AgentActionReview[]
  consultationRequests ConsultationBooking[] @relation("ConsultationRequester")
  assistantThreads     AssistantThread[]
  debateSessions       DebateSession[]       @relation("DebateLawyer")
}

model ClientProfile {
  id                 String                @id @default(cuid())
  userId             String                @unique
  phone              String?
  region             String?
  simpleLanguageMode Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cases              Case[]
  consultations      ConsultationBooking[]
}

model LawyerProfile {
  id              String                @id @default(cuid())
  userId          String                @unique
  publicSlug      String                @unique
  firmName        String?
  bio             String?
  specialties     String[]
  yearsExperience Int                   @default(0)
  hourlyRate      Float?
  fixedFeeFrom    Float?
  isPublic        Boolean               @default(true)
  verifiedBadge   Boolean               @default(false)
  rating          Float?
  city            String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments     CaseAssignment[]
  consultations   ConsultationBooking[]

  @@index([isPublic, verifiedBadge, rating])
  @@index([city])
}

model Case {
  id                   String                @id @default(cuid())
  title                String
  category             CaseCategory
  status               CaseStatus            @default(INTAKE)
  priority             Priority              @default(MEDIUM)
  stage                String                @default("Document Intake")
  description          String?
  caseHealthScore      Float                 @default(0)
  evidenceCompleteness Float                 @default(0)
  evidenceStrength     Float                 @default(0)
  deadlineRisk         Float                 @default(0)
  contractFairness     Float?
  draftReadiness       Float                 @default(0)
  escalationReadiness  Float                 @default(0)
  creatorId            String
  clientProfileId      String
  lawyerRequestedAt    DateTime?
  sharedWithLawyerAt   DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  creator              User                  @relation("CaseCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  client               ClientProfile         @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  assignments          CaseAssignment[]
  documents            Document[]
  evidenceItems        EvidenceItem[]
  timelineEvents       TimelineEvent[]
  deadlines            Deadline[]
  drafts               Draft[]
  comments             Comment[]
  internalNotes        InternalNote[]
  exportBundles        ExportBundle[]
  agentActionReviews   AgentActionReview[]
  consultationBookings ConsultationBooking[]
  redactionJobs        RedactionJob[]
  riskScores           RiskScore[]
  activityLogs         ActivityLog[]
  assistantThreads     AssistantThread[]
  debateSessions       DebateSession[]

  @@index([clientProfileId, updatedAt])
  @@index([creatorId, createdAt])
  @@index([status, updatedAt])
}

model CaseAssignment {
  id              String                @id @default(cuid())
  caseId          String
  lawyerProfileId String
  status          AssignmentStatus      @default(PENDING)
  feeProposal     Float?
  probability     Float?
  proposalNotes   String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  case            Case                  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  lawyer          LawyerProfile         @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)
  consultations   ConsultationBooking[]

  @@unique([caseId, lawyerProfileId])
  @@index([lawyerProfileId, status, updatedAt])
  @@index([caseId, status])
  @@index([caseId, updatedAt])
}

model Document {
  id                 String              @id @default(cuid())
  caseId             String
  uploadedById       String
  fileName           String
  filePath           String
  mimeType           String
  sizeBytes          Int
  fileType           DocumentType
  sourceType         UploadSource        @default(USER_UPLOAD)
  probableCategory   String?
  extractedText      String?
  aiSummary          String?
  tags               String[]
  confidence         Float?
  verificationStatus VerificationStatus  @default(UNREVIEWED)
  metadata           Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  case               Case                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploadedBy         User                @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  evidenceItems      EvidenceItem[]
  timelineEvents     TimelineEvent[]
  deadlines          Deadline[]
  comments           Comment[]
  redactionJobs      RedactionJob[]
  agentActionReviews AgentActionReview[]
  assistantThreads   AssistantThread[]

  @@index([caseId, createdAt])
  @@index([uploadedById, createdAt])
  @@index([fileType, createdAt])
}

model EvidenceItem {
  id                String    @id @default(cuid())
  caseId            String
  documentId        String?
  label             String
  summary           String?
  sourceType        String
  searchableText    String?
  extractedEntities Json?
  evidenceStrength  Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  case              Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  document          Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@index([documentId])
}

model TimelineEvent {
  id               String    @id @default(cuid())
  caseId           String
  sourceDocumentId String?
  title            String
  description      String?
  eventDate        DateTime
  confidence       Float?
  sourceLabel      String?
  isAiGenerated    Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  case             Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sourceDocument   Document? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([caseId, eventDate])
  @@index([caseId, createdAt])
  @@index([sourceDocumentId])
}

model Deadline {
  id               String         @id @default(cuid())
  caseId           String
  sourceDocumentId String?
  title            String
  dueDate          DateTime
  notes            String?
  status           DeadlineStatus @default(UPCOMING)
  importance       Priority       @default(MEDIUM)
  isAiDetected     Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  case             Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sourceDocument   Document?      @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([caseId, dueDate])
  @@index([caseId, status, dueDate])
  @@index([sourceDocumentId])
}

model Draft {
  id                 String             @id @default(cuid())
  caseId             String
  createdById        String
  verifiedById       String?
  type               DraftType
  title              String
  currentContent     String
  verificationStatus VerificationStatus @default(UNREVIEWED)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  case               Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy          User               @relation("DraftCreator", fields: [createdById], references: [id], onDelete: Cascade)
  verifiedBy         User?              @relation("DraftVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  versions           DraftVersion[]

  @@index([caseId, updatedAt])
  @@index([createdById, createdAt])
}

model DraftVersion {
  id            String   @id @default(cuid())
  draftId       String
  createdById   String
  versionNumber Int
  changeSummary String?
  content       String
  createdAt     DateTime @default(now())
  draft         Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)
  createdBy     User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([draftId, versionNumber])
  @@index([draftId, createdAt])
  @@index([createdById, createdAt])
}

model Comment {
  id         String            @id @default(cuid())
  caseId     String
  authorId   String
  documentId String?
  body       String
  visibility CommentVisibility @default(SHARED)
  pinned     Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  case       Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author     User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  document   Document?         @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@index([authorId, createdAt])
  @@index([documentId])
}

model InternalNote {
  id        String   @id @default(cuid())
  caseId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@index([authorId, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  kind      String
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model ExportBundle {
  id                  String   @id @default(cuid())
  caseId              String
  createdById         String
  bundleType          String
  title               String?
  summary             String?
  filePath            String
  includePrivateNotes Boolean  @default(false)
  metadata            Json?
  createdAt           DateTime @default(now())
  case                Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy           User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@index([createdById, createdAt])
}

model AgentActionReview {
  id                 String            @id @default(cuid())
  createdById        String
  caseId             String?
  documentId         String?
  assistantThreadId  String?
  assistantMessageId String?
  tool               String
  title              String
  message            String?
  status             String            @default("PENDING")
  arguments          Json
  resultMessage      String?
  resultAction       Json?
  reviewedAt         DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  createdBy          User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  case               Case?             @relation(fields: [caseId], references: [id], onDelete: SetNull)
  document           Document?         @relation(fields: [documentId], references: [id], onDelete: SetNull)
  assistantThread    AssistantThread?  @relation(fields: [assistantThreadId], references: [id], onDelete: SetNull)
  assistantMessage   AssistantMessage? @relation(fields: [assistantMessageId], references: [id], onDelete: SetNull)

  @@index([createdById, status])
  @@index([caseId, status])
  @@index([caseId, createdAt])
  @@index([createdById, createdAt])
  @@index([assistantThreadId])
}

model ConsultationBooking {
  id               String          @id @default(cuid())
  caseId           String
  clientProfileId  String
  lawyerProfileId  String
  assignmentId     String?
  requestedById    String
  status           String          @default("REQUESTED")
  scheduledAt      DateTime?
  durationMinutes  Int             @default(30)
  feeAmount        Float?
  paymentStatus    String          @default("UNPAID")
  paymentReference String?
  meetingMode      String          @default("ONLINE")
  meetingLink      String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  case             Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  client           ClientProfile   @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  lawyer           LawyerProfile   @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)
  assignment       CaseAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  requestedBy      User            @relation("ConsultationRequester", fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([caseId, status])
  @@index([caseId, scheduledAt])
  @@index([clientProfileId, status])
  @@index([clientProfileId, createdAt])
  @@index([lawyerProfileId, status])
  @@index([lawyerProfileId, createdAt])
  @@index([assignmentId])
}

model RedactionJob {
  id          String          @id @default(cuid())
  caseId      String
  documentId  String
  createdById String
  status      RedactionStatus @default(QUEUED)
  rules       Json
  outputPath  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  case        Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  document    Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy   User            @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@index([documentId])
  @@index([createdById, createdAt])
  @@index([status, updatedAt])
}

model RiskScore {
  id               String   @id @default(cuid())
  caseId           String
  dimension        String
  score            Float
  label            String
  rationale        String?
  confidence       Float?
  lastCalculatedAt DateTime @default(now())
  case             Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([caseId, dimension])
}

model ActivityLog {
  id        String   @id @default(cuid())
  caseId    String?
  actorId   String?
  action    String
  detail    String?
  metadata  Json?
  createdAt DateTime @default(now())
  case      Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@index([actorId, createdAt])
}

model AssistantThread {
  id                 String              @id @default(cuid())
  createdById        String
  caseId             String?
  documentId         String?
  title              String?
  scope              AssistantScope      @default(GENERAL)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdBy          User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  case               Case?               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  document           Document?           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  messages           AssistantMessage[]
  agentActionReviews AgentActionReview[]

  @@index([createdById, updatedAt])
  @@index([caseId, updatedAt])
  @@index([documentId, updatedAt])
}

model AssistantMessage {
  id                 String              @id @default(cuid())
  threadId           String
  role               MessageRole
  content            String
  sources            Json?
  confidence         Float?
  createdAt          DateTime            @default(now())
  thread             AssistantThread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  agentActionReviews AgentActionReview[]

  @@index([threadId, createdAt])
}

model DebateSession {
  id                 String       @id @default(cuid())
  caseId             String
  lawyerId           String
  title              String?
  status             DebateStatus @default(ACTIVE)
  startedAt          DateTime     @default(now())
  endsAt             DateTime
  outcomeProbability Float?
  outcomeLabel       String?
  evaluation         String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  case               Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  lawyer             User         @relation("DebateLawyer", fields: [lawyerId], references: [id], onDelete: Cascade)
  turns              DebateTurn[]

  @@index([caseId, createdAt])
  @@index([lawyerId, createdAt])
  @@index([status, endsAt])
}

model DebateTurn {
  id          String        @id @default(cuid())
  sessionId   String
  speaker     MessageRole
  content     String
  roundNumber Int
  createdAt   DateTime      @default(now())
  session     DebateSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, roundNumber, createdAt])
}
