# App/runtime connection. For Neon production, use the pooled -pooler host and keep a tiny Prisma pool per process.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mizan?connection_limit=1&pool_timeout=20"
# Migration/direct connection. For Neon, use the same database without the -pooler host.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/mizan"
JWT_SECRET="replace-me-with-a-long-random-secret"
AI_PROVIDER="gemini"
AI_ALLOW_MOCK_FALLBACK="false"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
CLOUDINARY_URL="cloudinary://your-api-key:your-api-secret@your-cloud-name"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_UPLOAD_FOLDER="mizan/uploads"
